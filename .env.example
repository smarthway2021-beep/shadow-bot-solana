# ============================================================
# Shadow Bot Solana - Arquivo de Configuracao
# Copie este arquivo para .env e preencha as chaves
# cp .env.example .env
# ============================================================

# --- HELIUS RPC (obrigatorio) ---
HELIUS_API_KEY=COLE_SUA_CHAVE_AQUI

# --- TELEGRAM (obrigatorio para alertas) ---
TELEGRAM_BOT_TOKEN=COLE_SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=COLE_SEU_CHAT_ID_AQUI

# --- CARTEIRA MONITORADA ---
TARGET_WALLET=4vw54BmAogeRV3vPKWyFet5yf8DTLcREzdSzx4rw9Ud9

# --- MODO DE OPERACAO ---
# SEMPRE true nos testes - nunca mude para false sem carteira configurada
SIMULATION_MODE=true

# --- POLLING (plano gratuito Helius: use 1.0 ou 2.0) ---
POLLING_INTERVAL_SEC=1.0
RPC_MAX_SIGNATURES=20

# --- FILTROS ANTI-RUG (baseados no perfil decu) ---
MAX_MARKET_CAP_ENTRY_USD=100000
MIN_LIQUIDITY_USD=500
MAX_TOP10_HOLDER_CONCENTRATION=0.35
MIN_POOL_AGE_SECONDS=20
REQUIRE_LP_LOCKED_OR_BURNED=true
REQUIRE_MINT_REVOKED=true
BLOCK_HONEYPOT=true
MAX_RUG_PERCENT=15.0

# --- LOGS ---
LOG_LEVEL=INFO
DB_PATH=data/shadow_bot.db
